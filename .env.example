# NoneBot / QQ adapter
DRIVER=~fastapi+~aiohttp
HOST=0.0.0.0
PORT=8080
QQ_BOTS=[{"id":"<appid>","token":"<token>","secret":"<secret>"}]

# Shared storage path inside containers (logger + processor must be identical)
CHAT_IMAGE_SAVE_DIR=/app/data/chat_images
GROUP_IMAGE_SAVE_DIR=/app/data/chat_images
GROUP_IMAGE_TIMEOUT_SEC=20
GROUP_IMAGE_RETRY_COUNT=3
GROUP_IMAGE_RETRY_DELAY_SEC=0.8

# NATS
CHAT_IMAGE_NATS_ENABLED=true
CHAT_IMAGE_NATS_SERVERS=nats://nats:4222
CHAT_IMAGE_NATS_SUBJECT=chat.image.tagger.task
CHAT_IMAGE_NATS_QUEUE_GROUP=chat-image-tagger-workers
CHAT_IMAGE_NATS_CLIENT_NAME=data-assistant
CHAT_IMAGE_NATS_CONNECT_TIMEOUT_SEC=5
CHAT_IMAGE_NATS_PUBLISH_TIMEOUT_SEC=3
CHAT_IMAGE_NATS_FALLBACK_LOCAL_QUEUE=true

# Tagger runtime
# logger service will override CHAT_IMAGE_TAGGER_ENABLED=false in compose
# processor service will override CHAT_IMAGE_TAGGER_ENABLED=true in compose
CHAT_IMAGE_TAGGER_ENABLED=false
CHAT_IMAGE_TAGGER_AUTO_RUN=false
CHAT_IMAGE_TAGGER_PYTHON=python
CHAT_IMAGE_TAGGER_ENTRY_SCRIPT=main.py
CHAT_IMAGE_TAGGER_CONFIG=config.ini
CHAT_IMAGE_TAGGER_BATCH_SIZE=16
CHAT_IMAGE_TAGGER_TIMEOUT_SEC=3600
CHAT_IMAGE_TAGGER_MAX_ATTEMPTS=3
CHAT_IMAGE_TAGGER_QUEUE_FILE=/app/data/chat_image_tagger_queue.json
CHAT_IMAGE_TAGGER_RUN_ROOT=/app/data/chat_image_tagger_runs
CHAT_IMAGE_TAGGER_AUDIT_LOG_FILE=/app/data/group_image_tags.jsonl
CHAT_IMAGE_TAGGER_KEEP_RUN_ARTIFACTS=false

# Host path for Eagle_AItagger_byWD1.4 (mounted into processor at /opt/tagger)
CHAT_IMAGE_TAGGER_TOOL_ROOT_HOST=/absolute/path/to/Eagle_AItagger_byWD1.4

# Optional telemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=data-assistant
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_INSECURE=true
