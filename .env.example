# NapCat reverse WebSocket (NapCat connects to data-logger)
NAPCAT_WS_HOST=0.0.0.0
NAPCAT_WS_PORT=8082
NAPCAT_WS_PATH=/onebot/v11/ws
NAPCAT_TOKEN=
NAPCAT_ACTION_TIMEOUT_SEC=8.0
NAPCAT_RECONNECT_SEC=5.0
NAPCAT_HEARTBEAT_TIMEOUT_SEC=60.0
NAPCAT_BOT_QQ=0

# Shared storage path inside containers (logger + processor must be identical)
CHAT_IMAGE_SAVE_DIR=/app/data/chat_images
GROUP_IMAGE_SAVE_DIR=/app/data/chat_images
GROUP_IMAGE_TIMEOUT_SEC=20
GROUP_IMAGE_RETRY_COUNT=3
GROUP_IMAGE_RETRY_DELAY_SEC=0.8

# NATS
CHAT_IMAGE_NATS_ENABLED=true
CHAT_IMAGE_NATS_SERVERS=nats://nats:4222
CHAT_IMAGE_NATS_SUBJECT=chat.image.tagger.task
CHAT_IMAGE_NATS_QUEUE_GROUP=chat-image-tagger-workers
CHAT_IMAGE_NATS_CLIENT_NAME=data-assistant
CHAT_IMAGE_NATS_CONNECT_TIMEOUT_SEC=5
CHAT_IMAGE_NATS_PUBLISH_TIMEOUT_SEC=3
CHAT_IMAGE_NATS_JETSTREAM_ENABLED=true
CHAT_IMAGE_NATS_STREAM=CHAT_IMAGE_TAGGER_TASKS
CHAT_IMAGE_NATS_STREAM_SUBJECTS=chat.image.tagger.task
CHAT_IMAGE_NATS_DURABLE=chat-image-tagger-workers
CHAT_IMAGE_NATS_ACK_WAIT_SEC=120
CHAT_IMAGE_NATS_MAX_DELIVER=10
# Backoff before JetStream redelivers a failed message (avoids hot-looping).
CHAT_IMAGE_NATS_NAK_DELAY_SEC=5
# Stream retention so the JetStream file store can't grow without bound.
# max_age in seconds (default 7d); -1 means unlimited for bytes/msgs.
CHAT_IMAGE_NATS_STREAM_MAX_AGE_SEC=604800
CHAT_IMAGE_NATS_STREAM_MAX_BYTES=-1
CHAT_IMAGE_NATS_STREAM_MAX_MSGS=-1
# Outbox relay (logger): re-publishes saved-but-unhanded-off tasks so a NATS
# outage at publish time never loses a tagging task. max_attempts=0 => unlimited.
CHAT_IMAGE_NATS_OUTBOX_RELAY_ENABLED=true
CHAT_IMAGE_NATS_OUTBOX_RELAY_INTERVAL_SEC=30
CHAT_IMAGE_NATS_OUTBOX_RELAY_BATCH_SIZE=100
CHAT_IMAGE_NATS_OUTBOX_MAX_ATTEMPTS=0
CHAT_IMAGE_NATS_OUTBOX_MIN_AGE_SEC=15

# Tagger runtime
# logger service will override CHAT_IMAGE_TAGGER_ENABLED=false in compose
# processor service will override CHAT_IMAGE_TAGGER_ENABLED=true in compose
# In Docker deployment, mount the same host image directory into both
# processor and Eagle tagger containers at /data/images.
CHAT_IMAGE_TAGGER_ENABLED=false
CHAT_IMAGE_TAGGER_AUTO_RUN=false
CHAT_IMAGE_TAGGER_BASE_URL=http://host.docker.internal:8000
CHAT_IMAGE_TAGGER_THRESHOLD=0.5
CHAT_IMAGE_TAGGER_USE_CHINESE_NAME=true
CHAT_IMAGE_TAGGER_TOP_K=20
CHAT_IMAGE_TAGGER_BATCH_SIZE=16
CHAT_IMAGE_TAGGER_TIMEOUT_SEC=3600
CHAT_IMAGE_TAGGER_MAX_ATTEMPTS=3
CHAT_IMAGE_TAGGER_DRAIN_INTERVAL_SEC=10
CHAT_IMAGE_TAGGER_HEALTHCHECK_PATH=/healthz
CHAT_IMAGE_TAGGER_QUEUE_FILE=/app/data/chat_image_tagger_queue.json
CHAT_IMAGE_TAGGER_AUDIT_LOG_FILE=/app/data/group_image_tags.jsonl

# Container registry deployment images
# docker compose uses local tags:
#   data-assistant-logger:${IMAGE_TAG}
#   data-assistant-processor:${IMAGE_TAG}
# ./init.sh pulls them from CONTAINER_REGISTRY/CONTAINER_NAMESPACE and retags locally.
# Leave CONTAINER_REGISTRY unset to use Docker Hub (docker.io).
# CONTAINER_REGISTRY=registry.example.com
CONTAINER_NAMESPACE=your-registry-namespace
IMAGE_TAG=latest

# PostgreSQL
POSTGRES_DSN=postgresql://admin:password@db:5432/app_db
# Per-query timeout (sec) so a hung query can't block the event loop forever.
POSTGRES_COMMAND_TIMEOUT_SEC=30
# Startup connect retry so the logger survives a not-yet-ready DB on cold boot.
POSTGRES_CONNECT_MAX_ATTEMPTS=30
POSTGRES_CONNECT_RETRY_DELAY_SEC=2
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10

# pgAdmin (dev only — change credentials in production)
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=pgadmin

# Optional telemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=data-assistant
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL_MS=60000

# Fluent Bit OTLP logs forwarding (compose fluent-bit service)
FB_OTLP_HOST=host.docker.internal
FB_OTLP_PORT=4318
FB_OTLP_LOGS_URI=/v1/logs
FB_OTLP_TLS=Off
FB_OTLP_TLS_VERIFY=Off
